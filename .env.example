# Root environment — used only for database tooling and monorepo scripts.
# Application variables live in apps/web/.env and apps/api/.env.

# Database (used by packages/database scripts: db:migrate, db:studio, db:seed)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres
DATABASE_MIGRATION_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# Ngrok scripts (scripts/ngrok-mercadolivre-callback, scripts/print-mercadolivre-callback-url)
NGROK_AUTHTOKEN=
NGROK_DOMAIN=
