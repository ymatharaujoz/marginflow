# Keep this file at the monorepo root. Local dev: the API and Next (`next.config.ts`) load these vars from here; you can still override with `apps/web/.env.local`.
#
# Public app metadata
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
WEB_APP_ORIGIN=http://localhost:3000
API_HOST=0.0.0.0
API_PORT=4000
API_DB_POOL_MAX=10

# Server-only environment
# Local development uses plain Postgres via DATABASE_URL.
# Production should point DATABASE_URL at Supabase Postgres.
DATABASE_URL=postgresql://postgres:root@localhost:5432/marginflow
BETTER_AUTH_SECRET=replace-me
BETTER_AUTH_URL=http://localhost:4000
GOOGLE_CLIENT_ID=replace-me
GOOGLE_CLIENT_SECRET=replace-me
AUTH_TRUSTED_ORIGINS=http://localhost:3000
STRIPE_SECRET_KEY=replace-me
STRIPE_WEBHOOK_SECRET=replace-me
STRIPE_PRICE_MONTHLY=price_monthly_replace_me
STRIPE_PRICE_ANNUAL=price_annual_replace_me

# Reserved for later Supabase app/service integrations.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me
