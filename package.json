{
  "name": "marginflow",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "corepack pnpm exec turbo run dev --parallel",
    "dev:root-shell": "next dev",
    "build": "corepack pnpm exec turbo run build && next build",
    "start": "next start",
    "lint": "corepack pnpm exec turbo run lint && eslint .",
    "typecheck": "corepack pnpm exec turbo run typecheck && tsc --noEmit",
    "test": "corepack pnpm exec turbo run test && vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@marginflow/domain": "workspace:*",
    "@marginflow/types": "workspace:*",
    "@marginflow/validation": "workspace:*",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@marginflow/eslint-config": "workspace:*",
    "@marginflow/tsconfig": "workspace:*",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^20.19.39",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.0",
    "eslint": "^9.39.0",
    "eslint-config-next": "16.2.4",
    "pnpm": "10.33.0",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.2.2",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1",
    "vitest": "^4.0.7"
  }
}
