# Lucreii Web — deploy template for Vercel
NEXT_PUBLIC_APP_URL=https://marginflow-web.vercel.app
NEXT_PUBLIC_API_BASE_URL=https://marginflow-production.up.railway.app
WEB_SESSION_SECRET=replace-with-long-random-secret

# Public branding/marketing
NEXT_PUBLIC_APP_NAME=Lucreii
NEXT_PUBLIC_APP_ICON=M
NEXT_PUBLIC_PRICE_MONTHLY_LABEL=R$ 99
NEXT_PUBLIC_PRICE_ANNUAL_LABEL=R$ 79
NEXT_PUBLIC_WHATSAPP_PHONE=
NEXT_PUBLIC_WHATSAPP_DEMO_URL=

# Local development only (never in production)
NEXT_PUBLIC_USE_MOCK_DATA=true
