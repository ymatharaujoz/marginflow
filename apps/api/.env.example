# MarginFlow API deploy template
# Keep local monorepo runtime reading the root `.env`.
# Use this file as a reference when configuring Railway variables.

# Runtime
API_HOST=0.0.0.0
API_PORT=4000
API_DB_POOL_MAX=10
NODE_ENV=production

# Public origins
BETTER_AUTH_URL=https://marginflow-web.vercel.app/api/auth
API_PUBLIC_BASE_URL=https://marginflow-production.up.railway.app
WEB_APP_ORIGIN=https://marginflow-web.vercel.app
AUTH_TRUSTED_ORIGINS=https://marginflow-web.vercel.app

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres
DATABASE_MIGRATION_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# Auth
BETTER_AUTH_SECRET=replace-with-long-random-secret
BETTER_AUTH_API_KEY=
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

# Billing
STRIPE_SECRET_KEY=sk_live_or_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_MONTHLY=price_replace_monthly
STRIPE_PRICE_ANNUAL=price_replace_annual

# Marketplace integration (optional unless Mercado Livre flow is enabled)
MERCADOLIVRE_CLIENT_ID=
MERCADOLIVRE_CLIENT_SECRET=
MERCADOLIVRE_REDIRECT_URI=https://marginflow-production.up.railway.app/integrations/mercadolivre/callback

# Optional local/testing helper. Ignored when NODE_ENV=production.
SYNC_RELAX_GUARDS=false
