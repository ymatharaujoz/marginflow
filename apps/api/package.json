{
  "name": "@marginflow/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --config vitest.config.ts",
    "start": "tsx src/main.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@marginflow/database": "workspace:*",
    "@marginflow/domain": "workspace:*",
    "@marginflow/types": "workspace:*",
    "@marginflow/validation": "workspace:*",
    "@nestjs/common": "^11.1.8",
    "@nestjs/core": "^11.1.8",
    "@nestjs/platform-fastify": "^11.1.8",
    "better-auth": "^1.6.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.44.7",
    "fastify": "^5.6.1",
    "reflect-metadata": "^0.2.2",
    "stripe": "^19.1.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "eslint": "^9.39.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.7"
  }
}
